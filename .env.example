# Drishi Enterprise
# Canonical environment contract for local and cloud deployments.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
APP_MODE=local
CLOUD_MODE=false
PORT=8000

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Leave empty for local solo development. Set in cloud/enterprise environments.
SECRET_CODE=

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
LLM_MODEL_OVERRIDE=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# STT
# Options: local, deepgram, sarvam, assemblyai
STT_BACKEND=local
STT_MODEL_OVERRIDE=Systran/faster-distil-whisper-small.en
DEEPGRAM_API_KEY=
SARVAM_API_KEY=
SARVAM_LANGUAGE=unknown

# -----------------------------------------------------------------------------
# Knowledge / answer preferences
# -----------------------------------------------------------------------------
CODING_LANGUAGE=python
RESUME_PATH=resume.txt

# -----------------------------------------------------------------------------
# Audio capture
# Set this when using PulseAudio / PipeWire monitor capture on Linux.
PULSE_SOURCE=

# -----------------------------------------------------------------------------
# Debug / diagnostics
# -----------------------------------------------------------------------------
INTERVIEW_DEBUG=0
VERBOSE=0
