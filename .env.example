# Interview Voice Assistant - Environment Variables
# Copy this file:  cp .env.example .env
# Then fill in your API key

# ── REQUIRED ─────────────────────────────────────────────────────
# Anthropic Claude API Key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPTIONAL: Cloud STT ───────────────────────────────────────────
# Deepgram Nova-3 — RECOMMENDED (fastest + most accurate, ~250ms)
# Free: $200 credit = ~780 hours. Paid: $0.0043/min (~$0.26/interview)
# Sign up at: https://console.deepgram.com/signup
DEEPGRAM_API_KEY=

# Sarvam AI — Indian accent optimized (~900ms, slower than Deepgram)
# Get free key at https://dashboard.sarvam.ai
SARVAM_API_KEY=

# ── OPTIONAL: Audio ───────────────────────────────────────────────
# Override PulseAudio source (auto-detected by run.sh normally)
# Run: pactl list short sources   to find available sources
PULSE_SOURCE=

# ── Render.com / Cloud Deployment ─────────────────────────────────
# Set CLOUD_MODE=true on Render — skips local audio, uses WebSocket
CLOUD_MODE=false

# Secret code to protect your cloud deployment.
# Anyone who knows this code can use your assistant.
# Set a strong value (e.g. a random password).
SECRET_CODE=
