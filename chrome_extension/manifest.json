{
  "manifest_version": 3,
  "name": "Drishi Enterprise",
  "version": "4.0",
  "description": "Drishi Browser Monitor — Real-time event tracking, screen sharing, and remote control for interview monitoring.",
  "permissions": [
    "activeTab",
    "storage",
    "system.display",
    "tabs",
    "scripting",
    "notifications",
    "windows",
    "offscreen",
    "desktopCapture",
    "tabCapture"
  ],
  "host_permissions": [
    "https://particulate-arely-unrenovative.ngrok-free.dev/*",
    "https://*.onrender.com/*",
    "https://meet.google.com/*",
    "https://zoom.us/*",
    "https://*.teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "monitor_content.js",
        "monitor_control_handler.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.programiz.com/*",
        "https://leetcode.com/*",
        "https://www.hackerrank.com/*",
        "https://codewars.com/*",
        "https://www.codewars.com/*",
        "https://app.codility.com/*",
        "https://codesignal.com/*",
        "https://www.codesignal.com/*",
        "https://replit.com/*",
        "https://colab.research.google.com/*"
      ],
      "js": [
        "typewriter.js",
        "coder_content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page_bridge.js",
        "monitor_capture.html",
        "monitor_state.js",
        "audio_processor_worklet.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_title": "Drishi Enterprise",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}